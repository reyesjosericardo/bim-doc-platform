# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-long-random-secret-min-32-chars"

# Prisma (same DB as backend or separate read replica)
DATABASE_URL="postgresql://user:password@localhost:5432/bim_doc_platform"

# Backend API (used in server components)
BACKEND_URL="http://localhost:4000"

# Backend API (used in client components / browser)
NEXT_PUBLIC_BACKEND_URL="http://localhost:4000"
